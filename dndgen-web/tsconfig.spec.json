/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "vitest",
      "@angular/localize"
    ],
    // TEMPORARY: Disable noImplicitAny during Jasmine->Vitest migration
    // Unmigrated Jasmine tests use loose typing in spy callbacks
    // This will be re-enabled in Phase 8 after all tests are migrated
    "noImplicitAny": false
  },
  "files": [
    "src/test-shims.d.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/test-helper.ts",
    "src/**/*.d.ts"
  ]
}
