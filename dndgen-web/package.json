{
  "name": "dndgen-web",
  "version": "2.5.3",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration development",
    "build:ci": "ng build --configuration production",
    "test": "ng test",
    "test:ci": "ng test --config vitest.config.ci.ts --outputFile.junit=./TestResults-DnDGen-Website.xml",
    "test:cd:rollgen": "ng test --config vitest.config.ci.ts src/app/roll --outputFile.junit=./TestResults-RollGen-Website.xml",
    "test:cd:treasuregen": "ng test --config vitest.config.ci.ts src/app/treasure --outputFile.junit=./TestResults-TreasureGen-Website.xml",
    "test:cd:charactergen": "ng test --config vitest.config.ci.ts src/app/character --outputFile.junit=./TestResults-CharacterGen-Website.xml",
    "test:cd:encountergen": "ng test --config vitest.config.ci.ts src/app/encounter --outputFile.junit=./TestResults-EncounterGen-Website.xml",
    "test:cd:dungeongen": "ng test --config vitest.config.ci.ts src/app/dungeon --outputFile.junit=./TestResults-DungeonGen-Website.xml",
    "test:cd:web": "ng test --config vitest.config.ci.ts src/app --outputFile.junit=./TestResults-AllGenerators-Website.xml"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@types/file-saver": "^2.0.7",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.0.0",
    "file-saver": "^2.0.5",
    "rxjs": "^7.8.2",
    "sweetalert2": "^11.26.20"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.5",
    "@angular/localize": "^21.1.5",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zone.js": "^0.16.1"
  }
}
